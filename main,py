import asyncio
import os
from telethon import TelegramClient
from telethon.sessions import StringSession
from telethon.tl.functions.account import UpdateStatusRequest
from aiohttp import web

# Берем данные из скрытых переменных сервера
API_ID = int(os.environ.get("API_ID", 0))
API_HASH = os.environ.get("API_HASH", "")
SESSION = os.environ.get("SESSION", "")

client = TelegramClient(StringSession(SESSION), API_ID, API_HASH)

async def keep_online():
    await client.start()
    print("Вечный онлайн успешно запущен на сервере!")
    while True:
        try:
            await client(UpdateStatusRequest(offline=False))
            await asyncio.sleep(300) # каждые 5 минут
        except Exception as e:
            print(f"Ошибка: {e}")
            await asyncio.sleep(60)

# Та самая веб-заглушка для Render
async def handle(request):
    return web.Response(text="Telegram-онлайн работает!")

async def web_server():
    app = web.Application()
    app.router.add_get('/', handle)
    runner = web.AppRunner(app)
    await runner.setup()
    port = int(os.environ.get("PORT", 8080))
    site = web.TCPSite(runner, '0.0.0.0', port)
    await site.start()

async def main():
    # Запускаем и веб-сервер, и Telegram-скрипт одновременно
    await asyncio.gather(keep_online(), web_server())

client.loop.run_until_complete(main())
